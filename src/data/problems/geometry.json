    {
      "id": "GEO-E01",
      "title": "Pythagorean Theorem",
      "difficulty": 2,
      "tier": "easy",
      "inputType": "short",
      "question": "A right triangle has legs 3 and 4. What is the hypotenuse?",
      "questionLatex": "a^2 + b^2 = c^2",
      "answer": "5",
      "solution": [
        {
          "step": 1,
          "title": "Apply theorem",
          "text": "c² = 3² + 4²",
          "latex": "c^2 = 9 + 16 = 25"
        },
        {
          "step": 2,
          "title": "Solve",
          "text": "c = √25 = 5",
          "latex": "c = \\sqrt{25} = 5"
        }
      ],
      "xp": 15,
      "tags": [
        "pythagorean",
        "right-triangle"
      ]
