        {
          "label": "D",
          "text": "30°"
        }
      ],
      "answer": "A",
      "solution": [
        {
          "step": 1,
          "title": "Sum of angles",
          "text": "Triangle angles sum to 180°",
          "latex": "\\angle_1 + \\angle_2 + \\angle_3 = 180°"
        },
        {
          "step": 2,
          "title": "Calculate",
          "text": "180 - 60 - 80 = 40",
