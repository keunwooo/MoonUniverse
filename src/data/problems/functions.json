      "title": "Function Evaluation",
      "difficulty": 1,
      "tier": "tutorial",
      "inputType": "multiple",
      "question": "If f(x) = 2x + 1, what is f(3)?",
      "questionLatex": "f(x) = 2x + 1",
      "choices": [
        {
          "label": "A",
          "text": "5"
        },
        {
          "label": "B",
          "text": "7",
          "correct": true
        },
        {
          "label": "C",
          "text": "6"
        },
        {
          "label": "D",
          "text": "9"
        }
      ],
      "answer": "B",
      "solution": [
        {
          "step": 1,
          "title": "Substitute x=3",
          "text": "f(3) = 2(3) + 1",
          "latex": "f(3) = 2(3) + 1"
        },
        {
          "step": 2,
          "title": "Calculate",
          "text": "f(3) = 7",
          "latex": "f(3) = 6 + 1 = 7"
        }
      ],
      "xp": 10,
