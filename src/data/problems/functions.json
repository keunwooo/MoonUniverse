    {
      "id": "FUN-T02",
      "title": "Domain Basics",
      "difficulty": 1,
      "tier": "tutorial",
      "inputType": "multiple",
      "question": "What value of x makes f(x) = 1/x undefined?",
      "questionLatex": "f(x) = \\frac{1}{x}",
      "choices": [
        {
          "label": "A",
          "text": "x = 0",
          "correct": true
        },
        {
          "label": "B",
          "text": "x = 1"
        },
        {
          "label": "C",
          "text": "x = -1"
        },
        {
          "label": "D",
          "text": "No value"
        }
      ],
      "answer": "A",
      "solution": [
        {
          "step": 1,
          "title": "Division by zero",
          "text": "A fraction is undefined when denominator = 0",
          "latex": "x \\neq 0"
        },
        {
          "step": 2,
          "title": "Answer",
          "text": "x = 0 makes f(x) undefined",
          "latex": "f(0) = \\frac{1}{0} \\;\\text{(undefined)}"
        }
      ],
      "xp": 10,
      "tags": [
        "domain"
      ]
    }
