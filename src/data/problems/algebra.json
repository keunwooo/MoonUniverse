      "tier": "hard",
      "inputType": "short",
      "question": "Using the quadratic formula, solve: 2x² + 3x - 2 = 0. Enter the positive root.",
      "questionLatex": "2x^2 + 3x - 2 = 0",
      "answer": "0.5",
      "answerLatex": "x = \\frac{1}{2}",
      "solution": [
        {
          "step": 1,
          "title": "Identify coefficients",
          "text": "a=2, b=3, c=-2",
          "latex": "a=2,\\; b=3,\\; c=-2"
        },
        {
          "step": 2,
          "title": "Apply formula",
          "text": "x = (-b ± √(b²-4ac)) / 2a",
