      "difficulty": 7,
      "tier": "expert",
      "inputType": "short",
      "question": "y = x²과 y = 4로 둘러싸인 영역의 넓이는? (소수 둘째자리까지)",
      "questionLatex": "\\int_{-2}^{2}(4-x^2)dx",
      "answer": "10.67",
      "solution": [
        { "step": 1, "title": "교점", "text": "x² = 4, x = ±2", "latex": "x = \\pm 2" },
        { "step": 2, "title": "적분", "text": "∫(4-x²)dx = [4x - x³/3]", "latex": "\\left[4x - \\frac{x^3}{3}\\right]_{-2}^{2}" },
        { "step": 3, "title": "계산", "text": "(8-8/3) - (-8+8/3) = 32/3 ≈ 10.67", "latex": "\\frac{32}{3} \\approx 10.67" }
      ],
      "xp": 50,
